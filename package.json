{
  "name": "garbo",
  "version": "5.4.4-rc.7",
  "description": "",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "migrate": "npx prisma migrate deploy",
    "seed:tags": "node --import tsx scripts/seed-tag-options.ts",
    "workers": "node --import tsx src/startWorkers.ts",
    "dev-workers": "node --import tsx --watch src/startWorkers.ts",
    "dev-board": "node -r dotenv/config --import tsx --watch src/index.ts",
    "dev-api": "node --import tsx --watch src/index.ts --api-only",
    "dev": "concurrently \"npm run dev-board\" \"npm run dev-workers\"",
    "import": "node --import=tsx scripts/import-spreadsheet-companies.ts",
    "evaluate-accuracy": "node --import=tsx scripts/garbo-evaluation/comparing-staging-production.ts",
    "test:scope1": "node --import tsx src/jobs/promptTestingFramework/run-suite.ts scope1",
    "test:scope2": "node --import tsx src/jobs/promptTestingFramework/run-suite.ts scope2",
    "test:scope12": "node --import tsx src/jobs/promptTestingFramework/run-suite.ts scope12",
    "test:scope3": "node --import tsx src/jobs/promptTestingFramework/run-suite.ts scope3",
    "analyze": "node src/jobs/promptTestingFramework/analyze-results.js",
    "wiki-push": "npx tsx scripts/push-existing-verified-data-to-wikidata.ts",
    "prisma": "prisma",
    "reset": "node --import tsx scripts/dev-reset.ts",
    "delete-report": "node --import tsx scripts/delete-report.ts",
    "eslint": "npx eslint src",
    "format": "npx prettier --write .",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "author": "Christian Landgren, William Ryder, Samuel Plumppu mfl",
  "license": "MIT License",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@bull-board/api": "^6.20.3",
    "@bull-board/fastify": "^6.20.3",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@google-cloud/storage": "^5.18.3",
    "@mendable/firecrawl-js": "^4.15.2",
    "@prisma/client": "^7.4.2",
    "@scalar/fastify-api-reference": "^1.48.0",
    "@types/node": "^25.3.5",
    "axios": "^1.13.6",
    "bullmq": "^5.70.4",
    "cheerio": "^1.2.0",
    "chromadb": "^3.3.1",
    "compromise": "^14.15.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "openai": "^6.27.0",
    "pdf2pic": "^3.2.0",
    "pino-http": "^11.0.0",
    "prisma-zod-generator": "^2.1.4",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "wikibase-edit": "^8.1.0",
    "wikibase-sdk": "^11.2.7",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/axios": "^0.14.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.6",
    "concurrently": "^9.2.1",
    "deepl-node": "^1.24.0",
    "eslint": "^10.0.2",
    "eslint-plugin-only-warn": "^1.2.1",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1",
    "prisma": "^6.19.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "uuid": "^9.0.1",
    "undici": ">=6.23.0"
  },
  "prisma": {
    "seed": "node --import=tsx prisma/seed.ts"
  }
}
